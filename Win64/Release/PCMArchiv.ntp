        <row id="Strings_rs_PCMBenutzerverwaltung_RechteBearbeiten" si="1250">
          <value>Die vordefinierten Rechte können nicht bearbeitet werden!</value>
          <lang id="de" rw="0" tm="1" time="20240117T080036Z">Die vordefinierten Rechte können nicht bearbeitet werden!</lang>
          <lang id="en" rw="0" tm="1" time="20240117T080923Z" fuzzy="99">The predefined rights cannot be edited!</lang>
          <lang id="fr" rw="0" tm="1" time="20240117T081421Z" fuzzy="99">Les droits prédéfinis ne peuvent pas être modifiés!</lang>
          <lang id="it" rw="0" tm="1" time="20240117T081411Z" fuzzy="99">I diritti predefiniti non possono essere modificati!</lang>
          <lang id="es" rw="0" tm="1" time="20240117T081405Z" fuzzy="99">¡Los derechos predefinidos no se pueden editar!</lang>
