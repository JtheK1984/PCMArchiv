        <row id="Strings_rs_PCM_ChooseModul" si="1241" st="4">
          <value>Bitte Modul wählen</value>
          <lang id="de" rw="0" tm="1" time="20240117T080030Z" fuzzy="100">Bitte Modul wählen</lang>
          <lang id="en" rw="0" tm="1" time="20240117T080922Z" fuzzy="100">Please select module</lang>
          <lang id="fr" rw="0" tm="1" time="20240117T081421Z" fuzzy="100">Veuillez choisir un module</lang>
          <lang id="it" rw="0" tm="1" time="20240117T081412Z" fuzzy="100">Selezionare il modulo</lang>
          <lang id="es" rw="0" tm="1" time="20240117T081405Z" fuzzy="100">Seleccione un módulo</lang>
        </row>
        <row id="Strings_rs_PCM_Style1" si="1284" st="4">
          <value>Soll der gewählte Style sofort übernommen werden? </value>
          <lang id="de" rw="0" tm="1" time="20240117T080030Z" fuzzy="97.9591827392578">Soll der gewählte Style sofort übernommen werden </lang>
          <lang id="en" rw="0" tm="1" time="20240117T080922Z" fuzzy="99">Should the selected style be applied immediately? </lang>
          <lang id="fr" rw="0" tm="1" time="20240117T081421Z" fuzzy="99">Le style choisi doit-il être appliqué immédiatement? </lang>
          <lang id="it" rw="0" tm="1" time="20240117T081411Z" fuzzy="99">Lo stile selezionato deve essere applicato immediatamente? </lang>
          <lang id="es" rw="0" tm="1" time="20240117T081405Z" fuzzy="99">¿Debe aplicarse inmediatamente el estilo seleccionado? </lang>
        </row>
        <row id="Strings_rs_PCM_Style2" si="1285" st="4">
          <value>Bei Ja wird das Programm neu gestartet.</value>
          <lang id="de" rw="0" tm="1" time="20240117T080102Z">Bei Ja wird das Programm neu gestartet.</lang>
          <lang id="en" rw="0" tm="1" time="20240117T080922Z" fuzzy="99">If Yes, the programme is restarted.</lang>
          <lang id="fr" rw="0" tm="1" time="20240117T081421Z" fuzzy="99">Si oui, le programme redémarre.</lang>
          <lang id="it" rw="0" tm="1" time="20240117T081411Z" fuzzy="99">Se sì, il programma viene riavviato.</lang>
          <lang id="es" rw="0" tm="1" time="20240117T081405Z" fuzzy="99">En caso afirmativo, el programa se reinicia.</lang>
        </row>
        <row id="Strings_rs_PCM_Sprachdatei" si="1272" st="4">
          <value>Sprachdatei kann nicht geladen werden</value>
          <lang id="de" rw="0" tm="1" time="20240117T080030Z" fuzzy="100">Sprachdatei kann nicht geladen werden</lang>
          <lang id="en" rw="0" tm="1" time="20240117T080922Z" fuzzy="100">Language file cannot be loaded</lang>
          <lang id="fr" rw="0" tm="1" time="20240117T081421Z" fuzzy="100">Le fichier de langue ne peut pas être chargé</lang>
          <lang id="it" rw="0" tm="1" time="20240117T081412Z" fuzzy="100">Il file di lingua non può essere caricato</lang>
          <lang id="es" rw="0" tm="1" time="20240117T081405Z" fuzzy="100">No se puede cargar el archivo de idioma</lang>
        </row>
        <row id="Strings_rs_PCMLog_KeineVerbindung1" si="1242">
          <value>Es konnte keine Verbindung zur Datenbank auf dem Server </value>
          <lang id="de" rw="0" tm="1" time="20240117T080030Z" fuzzy="100">Es konnte keine Verbindung zur Datenbank auf dem Server </lang>
          <lang id="en" rw="0" tm="1" time="20240117T080922Z" fuzzy="100">Could not connect to the database on the server </lang>
          <lang id="fr" rw="0" tm="1" time="20240117T081421Z" fuzzy="100">Impossible de se connecter à la base de données sur le serveur </lang>
          <lang id="it" rw="0" tm="1" time="20240117T081412Z" fuzzy="100">Impossibile connettersi al database sul server </lang>
          <lang id="es" rw="0" tm="1" time="20240117T081405Z" fuzzy="100">No se pudo conectar a la base de datos en el servidor </lang>
        </row>
